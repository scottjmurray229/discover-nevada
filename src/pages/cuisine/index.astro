---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Nevada Cuisine Guide', url: '/cuisine/' },
];

const pageTitle = 'Nevada Cuisine Guide — Eat Your Way Across the Silver State';
const pageDescription = 'A region-by-region guide to Nevada cuisine — from Las Vegas celebrity chef restaurants and Reno Basque dining to craft breweries, prime rib specials, and Lake Tahoe mountain cuisine.';

interface Dish {
  name: string;
  image?: string;
  destination: string;
  slug: string;
  price: string;
  description: string;
  tag?: string;
}

interface MenuSection {
  region: string;
  tagline: string;
  gradient: string;
  dishes: Dish[];
}

const menu: MenuSection[] = [
  {
    region: 'Las Vegas Metro',
    tagline: 'Celebrity chef empires, legendary buffets, and the $1.99 shrimp cocktail that started it all',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #E8654A 100%)',
    dishes: [
      {
        name: 'Shrimp Cocktail',
        image: '/images/cuisine/shrimp-cocktail.jpg',
        destination: 'Las Vegas',
        slug: 'las-vegas',
        price: '$2–8',
        description: 'The original Las Vegas loss leader. Since 1959, casinos have served chilled shrimp with cocktail sauce at absurdly low prices to keep gamblers on the floor. The Golden Gate Hotel\'s 99-cent version became legendary. Today you\'ll pay a bit more, but the tradition lives on at casino bars and oyster counters across the Strip and downtown.',
        tag: 'Iconic',
      },
      {
        name: 'Prime Rib Dinner',
        image: '/images/cuisine/prime-rib.jpg',
        destination: 'Las Vegas',
        slug: 'las-vegas',
        price: '$25–65',
        description: 'Las Vegas practically invented the cheap prime rib dinner as a casino promotion, and the tradition endures. Slow-roasted, thick-cut prime rib with creamy horseradish, baked potato, and a dinner roll — served at old-school casino steakhouses from the California Hotel to the Orleans. The best deals are off-Strip.',
        tag: 'Must-Try',
      },
      {
        name: 'Celebrity Chef Tasting Menu',
        image: '/images/cuisine/tasting-menu.jpg',
        destination: 'Las Vegas',
        slug: 'las-vegas',
        price: '$150–500',
        description: 'Las Vegas has more celebrity chef restaurants per square mile than anywhere on earth. Joel Robuchon, Gordon Ramsay, Guy Savoy, Thomas Keller — they all have outposts here. Multi-course tasting menus at restaurants like Joël Robuchon or é by José Andrés rival anything in Paris or New York.',
        tag: 'Fine Dining',
      },
      {
        name: 'Las Vegas Buffet',
        image: '/images/cuisine/las-vegas-buffet.jpg',
        destination: 'Las Vegas',
        slug: 'las-vegas',
        price: '$30–80',
        description: 'The Las Vegas buffet is an institution. Bacchanal Buffet at Caesars Palace and Wicked Spoon at the Cosmopolitan set the standard — hundreds of dishes spanning sushi, crab legs, prime rib, pasta, and desserts. Weekend brunch buffets with bottomless champagne are a Vegas rite of passage.',
        tag: 'Iconic',
      },
      {
        name: 'Craft Cocktails',
        image: '/images/cuisine/craft-cocktails.jpg',
        destination: 'Henderson',
        slug: 'henderson',
        price: '$14–22',
        description: 'Henderson and the Las Vegas metro have developed a serious craft cocktail scene beyond the Strip\'s frozen daiquiris. Bars like Herbs & Rye and Velveteen Rabbit serve prohibition-era classics and inventive originals. Henderson\'s growing restaurant row offers craft cocktails without the Strip markup.',
      },
      {
        name: 'Korean BBQ & Hot Pot',
        image: '/images/cuisine/korean-bbq.jpg',
        destination: 'Las Vegas',
        slug: 'las-vegas',
        price: '$25–45',
        description: 'Las Vegas\'s large Asian population drives an outstanding Korean BBQ and hot pot scene, especially along Spring Mountain Road — known locally as "Chinatown" despite being a pan-Asian food corridor. AYCE Korean BBQ restaurants serve tabletop grills with dozens of meats and banchan for one flat price.',
      },
    ],
  },
  {
    region: 'Southern Nevada',
    tagline: 'Dam-side dining, small-town charm, and desert canyon cuisine where history meets the plate',
    gradient: 'linear-gradient(135deg, #0D7377 0%, #4DB6AC 100%)',
    dishes: [
      {
        name: 'Boulder City Brewpub Burger',
        image: '/images/cuisine/boulder-city-burger.jpg',
        destination: 'Boulder City',
        slug: 'boulder-city',
        price: '$14–20',
        description: 'Boulder City — the only town in Nevada where gambling is illegal — has a charming main street with excellent brewpubs. Boulder Dam Brewing Company anchors the scene with craft beers and burgers in a historic building. The dam worker\'s town has become a foodie detour.',
        tag: 'Must-Try',
      },
      {
        name: 'Valley of Fire BBQ Picnic',
        image: '/images/cuisine/valley-fire-bbq.jpg',
        destination: 'Valley of Fire',
        slug: 'valley-of-fire',
        price: '$15–30',
        description: 'Pack a cooler and eat among the red sandstone formations. Overton — the gateway town — has no-frills diners and BBQ spots where ranchers and park visitors share tables. Sugar\'s Home Plate serves hearty portions of smoked meats and sides. An honest, unfussy meal before or after exploring the park.',
        tag: 'Heritage',
      },
      {
        name: 'Red Rock Canyon Trail Mix & Coffee',
        image: '/images/cuisine/red-rock-coffee.jpg',
        destination: 'Red Rock Canyon',
        slug: 'red-rock-canyon',
        price: '$5–12',
        description: 'Red Rock Canyon\'s proximity to Vegas means trail culture meets coffee culture. The nearby Summerlin neighborhood has excellent coffee roasters and bakeries where hikers fuel up before dawn starts. Grab a locally roasted espresso and house-made granola bars — this is how Las Vegas locals eat before hitting the trails.',
      },
      {
        name: 'Henderson Green Valley Ranch Dining',
        image: '/images/cuisine/henderson-dining.jpg',
        destination: 'Henderson',
        slug: 'henderson',
        price: '$20–60',
        description: 'Henderson offers Strip-quality dining at local prices. Green Valley Ranch Resort\'s restaurants serve everything from wood-fired pizza to sushi without the tourist markup. The Water Street district downtown has been revitalized with farm-to-table spots, taquerias, and cocktail lounges.',
      },
      {
        name: 'Mesquite-Grilled Steak',
        image: '/images/cuisine/mesquite-steak.jpg',
        destination: 'Boulder City',
        slug: 'boulder-city',
        price: '$30–55',
        description: 'The ranching tradition runs deep in southern Nevada. Steakhouses in Boulder City and Henderson serve thick-cut steaks grilled over mesquite and Nevada-raised beef. The Dillinger Food & Drinkery in Boulder City pairs its steaks with craft cocktails in a speakeasy-style setting named after the gangster era.',
        tag: 'Heritage',
      },
      {
        name: 'Date Shake',
        image: '/images/cuisine/date-shake.jpg',
        destination: 'Boulder City',
        slug: 'boulder-city',
        price: '$6–9',
        description: 'A thick milkshake blended with Medjool dates from nearby desert farms. Creamy, naturally sweet, and perfect for cooling down after a day at Hoover Dam or Lake Mead. Date farms along the drive toward Laughlin sell fresh dates and date-based treats you won\'t find elsewhere.',
      },
    ],
  },
  {
    region: 'Northern Nevada',
    tagline: 'Basque family-style feasts, mountain-town craft dining, and cowboy steakhouses with 150 years of history',
    gradient: 'linear-gradient(135deg, #1A2332 0%, #6A1B9A 50%, #D4A853 100%)',
    dishes: [
      {
        name: 'Basque Family-Style Dinner',
        image: '/images/cuisine/basque-dinner.jpg',
        destination: 'Reno',
        slug: 'reno',
        price: '$25–45',
        description: 'Reno is the capital of Basque cuisine in America. Louis\' Basque Corner and the Santa Fe Hotel serve multi-course family-style dinners: picon punch to start, then soup, salad, beans, bread, a main of lamb, oxtail, or sweetbreads, and flan for dessert. One price, all you can eat, communal tables. A Reno tradition since Basque shepherds settled here in the 1800s.',
        tag: 'Iconic',
      },
      {
        name: 'Picon Punch',
        image: '/images/cuisine/picon-punch.jpg',
        destination: 'Reno',
        slug: 'reno',
        price: '$8–12',
        description: 'Nevada\'s signature cocktail — a potent mix of Amer Picon (a bitter French aperitif), grenadine, soda water, and a brandy float. It was the drink of Basque shepherds in Nevada\'s high desert, and it\'s still served at every Basque restaurant and many bars across Reno and northern Nevada. Sweet, bitter, and dangerously smooth.',
        tag: 'Iconic',
      },
      {
        name: 'Lake Tahoe Mountain Cuisine',
        image: '/images/cuisine/tahoe-mountain-cuisine.jpg',
        destination: 'Lake Tahoe',
        slug: 'lake-tahoe',
        price: '$35–80',
        description: 'Lake Tahoe\'s restaurant scene blends mountain lodge warmth with California wine country sophistication. Restaurants like Lone Eagle Grille serve elk chops and pan-seared trout with panoramic lake views. The South Shore has a more casual vibe — craft breweries, wood-fired pizza, and après-ski dining.',
        tag: 'Must-Try',
      },
      {
        name: 'All-You-Can-Eat Crab Legs',
        image: '/images/cuisine/crab-legs.jpg',
        destination: 'Reno',
        slug: 'reno',
        price: '$45–65',
        description: 'Reno\'s casino buffets rival Las Vegas for value, and AYCE crab legs are the crown jewel. The Atlantis, Peppermill, and Grand Sierra Resort all serve snow crab and king crab at their buffets — a fraction of what you\'d pay in any other city. Weekend dinner buffets are the best deal.',
      },
      {
        name: 'Virginia City Saloon Fare',
        image: '/images/cuisine/virginia-city-saloon.jpg',
        destination: 'Virginia City',
        slug: 'virginia-city',
        price: '$12–25',
        description: 'Eat where the Comstock miners ate. Virginia City\'s historic saloons serve hearty meals — thick burgers, chili, and steaks — in buildings that haven\'t changed much since the 1860s silver rush. The Bucket of Blood Saloon and the Delta Saloon serve drinks and food in authentic Old West atmosphere.',
        tag: 'Heritage',
      },
      {
        name: 'Craft Beer & Pizza',
        image: '/images/cuisine/craft-beer-pizza.jpg',
        destination: 'Carson City',
        slug: 'carson-city',
        price: '$6–8 pints / $14–22 pizza',
        description: 'Carson City and the Reno-Tahoe corridor have developed a thriving craft brewery scene. IMBIB Custom Brews in Reno, Shoe Tree Brewing in Carson City, and South Lake Brewing Company in Tahoe anchor a growing beer trail. Pair local IPAs and lagers with wood-fired pizza and you\'ve got a Nevada brewery crawl.',
      },
    ],
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  schemaData={{ title: pageTitle, description: pageDescription }}
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <header class="menu-hero">
    <video class="menu-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/cuisine-hero.mp4" type="video/mp4" />
    </video>
    <div class="menu-hero-gradient"></div>
    <div class="menu-hero-noise"></div>
    <div class="menu-hero-content">
      <h1 class="menu-hero-title">The Nevada Menu</h1>
      <p class="menu-hero-subtitle">Celebrity chef tasting menus on the Strip, Basque family-style feasts in Reno, Lake Tahoe mountain cuisine, legendary prime rib specials, and the shrimp cocktail that started it all — eat your way across three distinct regions.</p>
      <div class="menu-hero-meta">
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Dishes</span>
          <span class="menu-hero-meta-value">18</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Regions</span>
          <span class="menu-hero-meta-value">3</span>
        </div>
        <div class="menu-hero-meta-item">
          <span class="menu-hero-meta-label">Destinations</span>
          <span class="menu-hero-meta-value">10</span>
        </div>
      </div>
    </div>
    <div class="menu-scroll-hint">Scroll<br />&#8595;</div>
  </header>

  <!-- Breadcrumb -->
  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <!-- Personal intro -->
  <section class="menu-personal reveal">
    <div class="container-content">
      <blockquote class="menu-personal-quote">
        <p>I came to Nevada expecting buffets and steakhouses. What I found was something far more interesting — a food culture shaped by Basque shepherds who brought family-style dining to Reno, a Las Vegas Strip where every celebrity chef on the planet has a restaurant, and a craft brewery scene that stretches from Carson City to Lake Tahoe. The shrimp cocktail is iconic, the prime rib deals are unbeatable, and once you sit down at a Basque dinner in Reno, you understand that Nevada's food story goes far deeper than the casino floor.</p>
        <cite>— Scott</cite>
      </blockquote>
    </div>
  </section>

  <!-- Menu Intro -->
  <section class="menu-intro reveal">
    <div class="container-content">
      <div class="menu-intro-card">
        <p class="menu-intro-text">Think of this as your tasting menu for Nevada. We've organized the state's essential dishes by region — <strong>Las Vegas Metro</strong> with its celebrity chef empire and casino classics, <strong>Southern Nevada</strong> with its dam-side dining and desert charm, and <strong>Northern Nevada</strong> with its Basque heritage and mountain-town flavors. Click any dish to explore the destination where it's famous.</p>
        <div class="menu-intro-legend">
          <span class="menu-tag menu-tag--heritage">Heritage</span>
          <span class="menu-tag menu-tag--musttry">Must-Try</span>
          <span class="menu-tag menu-tag--iconic">Iconic</span>
          <span class="menu-tag menu-tag--finedining">Fine Dining</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Sections by Region -->
  {menu.map((section) => (
    <section class="menu-region reveal">
      <div class="container-content">
        <div class="menu-region-header" style={`background: ${section.gradient};`}>
          <div class="menu-region-header-inner">
            <h2 class="menu-region-name">{section.region}</h2>
            <p class="menu-region-tagline">{section.tagline}</p>
            <span class="menu-region-count">{section.dishes.length} dishes</span>
          </div>
          <div class="menu-region-ornament">&#9733;</div>
        </div>

        <div class="menu-dish-grid">
          {section.dishes.map((dish) => (
            <a href={`/destinations/${dish.slug}/`} class="menu-dish-card">
              <div class="menu-dish-media" style={`background: ${section.gradient};`}>
                {dish.image && (
                  <img src={dish.image} alt={`${dish.name} — ${dish.destination}`} class="menu-dish-img" loading="lazy" />
                )}
                {dish.tag && (
                  <span class={`menu-tag menu-tag--${dish.tag.toLowerCase().replace(/[^a-z]/g, '')}`}>{dish.tag}</span>
                )}
              </div>
              <div class="menu-dish-body">
                <div class="menu-dish-top">
                  <h3 class="menu-dish-name">{dish.name}</h3>
                  <span class="menu-dish-price">{dish.price}</span>
                </div>
                <p class="menu-dish-destination">{dish.destination}</p>
                <p class="menu-dish-desc">{dish.description}</p>
                <span class="menu-dish-cta">Explore {dish.destination} &rarr;</span>
              </div>
              <div class="menu-dish-overlay">
                <p class="menu-dish-overlay-desc">{dish.description}</p>
                <span class="menu-dish-overlay-cta">Explore {dish.destination} &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="menu-cta-section reveal">
    <div class="container-content">
      <div class="menu-cta-card">
        <h2 class="menu-cta-heading">Plan Your Food Trip</h2>
        <p class="menu-cta-text">Tell our AI planner which dishes you want to try and it will build a region-by-region itinerary — with the best restaurants, food trucks, and local favorites.</p>
        <a href="/plan/" class="menu-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <FAQ items={[
    { question: "What food is Nevada known for?", answer: "Nevada is best known for its Las Vegas celebrity chef restaurants, Basque family-style dining in Reno (a tradition dating back to the 1800s), legendary shrimp cocktails, prime rib specials, and casino buffets. Beyond the casino floor, Nevada has a growing craft brewery scene, excellent Korean and Asian cuisine along Las Vegas's Spring Mountain Road, and Lake Tahoe mountain cuisine featuring elk, trout, and local produce." },
    { question: "What is Basque food and where do I find it?", answer: "Basque cuisine comes from the Basque people of Spain and France who immigrated to Nevada as sheepherders in the 1800s. Reno is the American capital of Basque dining. Restaurants like Louis' Basque Corner and the Santa Fe Hotel serve multi-course family-style meals: picon punch, soup, salad, beans, bread, a meat entree (lamb, oxtail, or sweetbreads), and dessert — all for one price at communal tables. It's one of Nevada's most unique food experiences." },
    { question: "Where is the best food in Nevada?", answer: "Las Vegas is the undisputed dining capital with more celebrity chef restaurants than any city on earth — from Joel Robuchon to Gordon Ramsay. Reno offers uniquely Basque dining found nowhere else in the country. Lake Tahoe has upscale mountain cuisine with stunning views. Henderson and Summerlin have excellent local restaurants without Strip prices. Virginia City's historic saloons serve authentic Old West fare." },
    { question: "Are Las Vegas buffets worth it?", answer: "The top-tier buffets absolutely are. Bacchanal Buffet at Caesars Palace and Wicked Spoon at the Cosmopolitan serve restaurant-quality food across hundreds of stations — sushi, crab legs, prime rib, made-to-order pasta, and elaborate desserts. Expect to pay $40-80 depending on the meal and day. Weekend brunch buffets with bottomless champagne are the best value. Budget buffets on Fremont Street offer lower prices but lower quality." },
    { question: "What is a picon punch?", answer: "A picon punch is Nevada's signature cocktail — a mix of Amer Picon (a bitter French orange liqueur), grenadine, soda water, and a brandy float. Basque shepherds brought it to Nevada, and it's now served at Basque restaurants and many bars across Reno and northern Nevada. It's sweet, bitter, and stronger than it tastes. Order one at Louis' Basque Corner in Reno for the authentic experience." },
    { question: "How much does food cost in Nevada?", answer: "Casino buffets: $30-80. Prime rib specials: $15-35. Casual dining: $15-30 per person. Mid-range restaurants: $30-60 per person. Celebrity chef fine dining on the Strip: $150-500 for tasting menus. Off-Strip and Henderson restaurants are 30-50% cheaper than Strip prices for comparable quality. A daily food budget of $40-70 covers three solid meals comfortably if you eat off-Strip." },
  ]} />

  <!-- Email Capture -->
  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get Our Free Nevada Food Guide"
      description="A region-by-region PDF guide to Nevada cuisine — with the best restaurants, casino dining deals, and dishes you can't miss."
      bullets={[
        'All 18 dishes with where to find the best version',
        'Price guide — from $2 shrimp cocktails to $500 tasting menus',
        'Reno Basque restaurant guide with dinner reservation tips',
        'Best casino buffet rankings and value tips',
      ]}
      guideTag="pillar-cuisine"
    />
  </div>

  <!-- Cross-links -->
  <section class="menu-crosslinks reveal">
    <div class="container-content">
      <h3 class="menu-crosslinks-heading">Explore More</h3>
      <div class="menu-crosslinks-grid">
        <a href="/history/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127963;</span>
          <span class="menu-crosslink-label">Nevada History</span>
          <span class="menu-crosslink-desc">Mining booms, atomic testing, and the rise of Las Vegas</span>
        </a>
        <a href="/hiking/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#9968;</span>
          <span class="menu-crosslink-label">Hiking Guide</span>
          <span class="menu-crosslink-desc">20+ trails from Red Rock Canyon to Wheeler Peak</span>
        </a>
        <a href="/destinations/" class="menu-crosslink-card">
          <span class="menu-crosslink-icon">&#127965;</span>
          <span class="menu-crosslink-label">All Destinations</span>
          <span class="menu-crosslink-desc">10 Nevada destinations with honest reviews and tips</span>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Scroll Reveal Observer -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  /* ================================================================
     HERO — Warm, food-inspired gradient
     ================================================================ */
  .menu-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5rem var(--space-6) 60px;
    overflow: hidden;
  }

  .menu-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .menu-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.15) 40%, rgba(0,0,0,0.55) 100%);
  }

  .menu-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  .menu-hero-content {
    position: relative;
    z-index: 3;
    max-width: 720px;
  }

  .menu-hero-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 var(--space-3);
  }

  .menu-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    max-width: 580px;
  }

  .menu-hero-meta {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .menu-hero-meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .menu-hero-meta-label {
    font-size: 0.65rem;
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .menu-hero-meta-value {
    font-size: 1.1rem;
    font-weight: var(--weight-bold);
    color: #fff;
  }

  .menu-scroll-hint {
    position: absolute;
    bottom: 16px;
    right: var(--space-6);
    z-index: 3;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.35);
    text-align: center;
    animation: menuBounce 2s ease-in-out infinite;
  }

  @keyframes menuBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ================================================================
     MENU INTRO
     ================================================================ */
  .menu-intro {
    padding: var(--space-8) 0 var(--space-4);
  }

  .menu-intro-card {
    background: var(--color-white);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .menu-intro-text {
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.7;
    max-width: 640px;
    margin: 0 auto var(--space-4);
  }

  .menu-intro-legend {
    display: flex;
    justify-content: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ================================================================
     TAGS
     ================================================================ */
  .menu-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 6px;
    line-height: 1.4;
  }

  .menu-tag--heritage {
    background: rgba(191, 54, 12, 0.1);
    color: #BF360C;
  }

  .menu-tag--musttry, .menu-tag--mustry {
    background: rgba(13, 115, 119, 0.1);
